<div style="text-align: center; padding: 2rem;">
  <div style="font-size: 4rem; margin-bottom: 1rem;">🚀</div>
  <h1 style="font-size: 2.5rem; font-weight: 700; color: #f8fafc; margin-bottom: 0.5rem;">
    Hello, World!
  </h1>
  <p style="font-size: 1.2rem; color: #94a3b8; margin-bottom: 2rem;">
    Votre application Ruby on Rails est en ligne.
  </p>
  <div style="background: #1e293b; border-radius: 0.75rem; padding: 1.5rem; display: inline-block; text-align: left; min-width: 320px;">
    <p style="color: #64748b; font-size: 0.85rem; margin-bottom: 0.75rem; font-family: monospace; text-transform: uppercase; letter-spacing: 0.05em;">Environnement</p>
    <p style="font-family: monospace; color: #7dd3fc;">
      Rails <%= Rails.version %> · Ruby <%= RUBY_VERSION %>
    </p>
    <p style="font-family: monospace; color: #86efac; margin-top: 0.25rem;">
      ENV: <%= Rails.env %>
    </p>
    <p style="font-family: monospace; color: #fbbf24; margin-top: 0.25rem;">
      Host: <%= `hostname`.strip %>
    </p>
  </div>
</div>
